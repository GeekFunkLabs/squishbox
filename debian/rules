#!/usr/bin/make -f

export DH_VERBOSE=1
export PYBUILD_NAME=squishbox

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_build:
	# Build main python project
	dh_auto_build

	# Build fluidpatcher
	cd fluidpatcher && python3 -m build --wheel --no-isolation

	# Build ttymidi
	$(MAKE) -C ttymidi

override_dh_auto_install:
	# Install squishbox python package
	dh_auto_install

	# Install fluidpatcher wheel into package root
	pip3 install \
	    --no-deps \
	    --root=$(CURDIR)/debian/squishbox-fluidpatcher \
	    --prefix=/usr \
	    fluidpatcher/dist/*.whl

	# Install system tools
	$(MAKE) -C ttymidi \
	    DESTDIR=$(CURDIR)/debian/squishbox-system \
	    install

override_dh_auto_test:
	@echo "Skipping tests (requires GPIO hardware)"

